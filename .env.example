# Copy to .env for local Docker runs. Do not commit real secrets.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct
LLM_MAX_TOKENS=700
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=12

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=incident_ai
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse

REDPANDA_BROKERS=redpanda:9092
PRIVACY_SHIELD_URL=http://privacy-shield:8080
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
ROUTING_CONFIDENCE_THRESHOLD=0.85
FAST_PATH_SIMILARITY_THRESHOLD=0.95
RAG_SIMILARITY_THRESHOLD=0.70
RAG_TOP_K=5
