# Copy to .env for local Docker runs. Do not commit real secrets.
APP_ENV=production
APP_VERSION=1.0.0
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
TRUSTED_HOSTS=*
MAX_REQUEST_BODY_BYTES=64000
ROUTE_TIMEOUT_SECONDS=45

REDPANDA_EXTERNAL_HOST=localhost
REDPANDA_EXTERNAL_PORT=19092
REDPANDA_ADMIN_PORT=9644
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
PRIVACY_SHIELD_PORT=8080
API_GATEWAY_PORT=8000
REVIEW_UI_PORT=8081
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct
LLM_MAX_TOKENS=700
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=12
LLM_MAX_RETRIES=1
LLM_MAX_INPUT_CHARS=8000
LLM_MAX_CONTEXT_CHARS=12000
LLM_MAX_CONTEXT_ITEMS=5

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=incident_ai
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_CONNECT_TIMEOUT_SECONDS=5
CLICKHOUSE_SEND_RECEIVE_TIMEOUT_SECONDS=30

REDPANDA_BROKERS=redpanda:9092
PRIVACY_SHIELD_URL=http://privacy-shield:8080
PRIVACY_TIMEOUT_SECONDS=3
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_LOCAL_FILES_ONLY=true
EMBEDDING_DIM=384
ROUTING_CONFIDENCE_THRESHOLD=0.85
FAST_PATH_SIMILARITY_THRESHOLD=0.95
RAG_SIMILARITY_THRESHOLD=0.70
RAG_TOP_K=5
APPROVED_KNOWLEDGE_SOURCES=6StringNinja/synthetic-servicenow-incidents,curated,historical,seed
GRAFANA_ADMIN_PASSWORD=admin
